{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "labels": ["dependencies"],
  "extends": [
    "config:recommended",
    ":separatePatchReleases",
    ":separateMultipleMajorReleases"
  ],
  "allowedUnsafeExecutions": [
    "gradleWrapper"
  ],
  "rebaseWhen": "auto",
  "packageRules": [
    {
      "groupName": "kotlin",
      "matchPackageNames": [
        "/org\\.jetbrains\\.kotlin:/",
        "/org\\.jetbrains\\.kotlin\\./"
      ]
    },
    {
      "groupName": "ktlint",
      "matchPackageNames": [
        "/com\\.pinterest\\.ktlint/",
        "/org\\.jlleitschuh\\.gradle\\.ktlint/"
      ]
    }
  ]
}
